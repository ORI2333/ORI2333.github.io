{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "blog": "python tools/blog/run_blog.py",
    "blog:check": "python tools/blog/blog_cli.py check-env",
    "blog:build-exe": "python tools/blog/build_exe.py",
    "blog:cli": "python tools/blog/blog_cli.py status",
    "blog:new": "python tools/blog/blog_cli.py new",
    "blog:import": "python tools/blog/blog_cli.py import",
    "blog:sync": "python tools/blog/blog_cli.py sync",
    "blog:build": "python tools/blog/blog_cli.py build",
    "blog:preview": "python tools/blog/blog_cli.py preview",
    "blog:publish": "python tools/blog/blog_cli.py publish",
    "blog:deploy-hk": "python tools/blog/blog_cli.py deploy-hk",
    "blog:all": "python tools/blog/blog_cli.py all",
    "blog:status": "python tools/blog/blog_cli.py status",
    "deploy:hk:discover": "python tools/hk_deploy/discover_hk_server.py",
    "deploy:hk": "python tools/hk_deploy/deploy_hk.py",
    "deploy:hk:setup": "python tools/hk_deploy/setup_hk_server.py",
    "push:static": "npm run clean && npm run build && npm run deploy",
    "push": "git add -A && git reset -- public db.json .deploy_git && (git diff --cached --quiet || git commit -m \"chore: sync source\") && git push origin HEAD",
    "source:status": "git status --short",
    "source:push": "npm run push",
    "server": "hexo server"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
    "hexo": "^7.3.0",
    "hexo-deployer-git": "^4.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-kratos-rebirth": "^3.0.1"
  }
}
